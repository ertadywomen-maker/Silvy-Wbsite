{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category (e.g., Men, Women, Kids)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["name", "order"]
    },
    "Product": {
      "title": "Product",
      "description": "Shoe model in the catalog",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Model code" },
        "name": { "type": "string", "description": "Model name" },
        "categoryId": { "type": "string", "description": "Reference to Category ID" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "pairsPerBox": { "type": "number", "description": "Number of pairs in one box" },
        "pricePerPair": { "type": "number", "description": "Price per single pair" },
        "totalBoxPrice": { "type": "number", "description": "Total price for the box (pairsPerBox * pricePerPair)" },
        "isAvailable": { "type": "boolean", "description": "Whether the product is in stock" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["code", "name", "categoryId", "imageUrl", "pairsPerBox", "pricePerPair", "totalBoxPrice", "isAvailable"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of shoe products"
    }
  }
}
